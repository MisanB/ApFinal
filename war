public class card {
    
    private int Suit; //index
    private int Rank;
    
    public card(int Suit, int Rank)
    {
        this.Suit = Suit;
        this.Rank = Rank;
    }
    
    public int getRank()
    {
        return Rank;
    }
    public int getSuit()
    {
        return Suit;
    }
    
    public String toString()
    {
        if (Rank < 11)
        {
            return Rank + " of " + Deck.getSuit(Suit);
        }
        else if (Rank == 11)
        {
            return "jack of " + Deck.getSuit(Suit);
        }
        else if (Rank == 12)
        {
            return "Queen of " + Deck.getSuit(Suit);
        }
        else if (Rank == 13)
        {
            return "King of " + Deck.getSuit(Suit);
        }
        else // if (Rank == 14)
        {
            return "Ace of " + Deck.getSuit(Suit);
        }
    }
    
    public static String stringRank(int rank)
    {
        if (rank < 11)
        {
            return "" + rank;
        }
        else if (rank == 11)
        {
            return "jack";
        }
        else if (rank == 12)
        {
            return "Queen";
        }
        else if (rank == 13)
        {
            return "King";
        }
        else // if (rank == 14)
        {
            return "Ace";
        }
    }
    
    public boolean is_greater(card Other)
    {
        if (Rank != Other.getRank())
        {
            return Rank > Other.getRank();
        }
        else
        {
            return Suit < Other.getSuit();
        }
    }
}

