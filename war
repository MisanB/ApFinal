public class hand extends Deck { 
    
    
    public hand()
    {
        DeckOfCards.clear();
    }
    
    public void dealCards(Deck cards, int amount )
    {
        for (int i = 0 ; i < amount ; i++)
        {
            int index = cards.pickIndex();
            add(cards.get(index));
            cards.remove(index);
        }
    }
    
    public void takeCard(Deck cards, int index)
    {
        add(cards.get(index));
        cards.remove(index);
    }
    
    public card takeOutCard(int index)
    {
        if (index >= size())
        {
            return null;
        }
        
        card newcard = get(index);
        remove(index);
        
        return newcard;
    }
    
    public void depositCards(Deck deckDepositing)
    {
        for (int i = 0 ; i < deckDepositing.size() ; i++)
        {
            takeCard(deckDepositing, i);
        }
    }
    
    public String toString()
    {
        String value = "[";
        
        for (card cards : DeckOfCards)
        {
            value += cards + " : ";
            value += "\n";
        }
        
        return value + "]";
    }
    
}

