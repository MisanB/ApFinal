            AiDeck.remove(AiIndex);
            
            if (printing) System.out.println(" Player Wins! ");
            
            return true;
        }
        else
        {
            AiDeck.add(PlayerDeck.get(PlayerIndex));
            PlayerDeck.remove(PlayerIndex);
            
           if (printing)  System.out.println(" Ai Wins! ");
           
           return false;
        }
    }
    
